---
import Page from "../layouts/Page.astro";
import SI_Display from "../components/SI_Display.svelte";
import json from "../data.json";
import { SI_Leader } from "../si.js";

const leaders: Map<String, SI_Leader> = (() => {
  const map = new Map<String, SI_Leader>();
  for (const leader of json) {
    map.set(leader.name, leader);
  }
  return map;
})();
---

<script src="../../node_modules/flowbite/dist/flowbite.min.js"></script>

<Page title="Sessions">
  <SI_Display client:load data={leaders} names={Array.from(leaders.keys())} />
</Page>
